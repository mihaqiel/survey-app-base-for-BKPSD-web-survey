// app/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// GLOBAL PERIOD
model Periode {
  id        String    @id @default(cuid())
  label     String    @default("Global Access")
  status    String    @default("AKTIF")  // AKTIF | NONAKTIF
  token     String    @unique
  startDate DateTime?
  endDate   DateTime?
  respon    Respon[]
  createdAt DateTime  @default(now())
}

// FIXED SERVICE (22 Layanan)
model Layanan {
  id       String   @id @default(cuid())
  nama     String
  kategori String?  // for Tree grouping
  respon   Respon[]
}

// EMPLOYEE
model Pegawai {
  id     String   @id @default(cuid())
  nama   String
  respon Respon[]
}

// RESPONSE
model Respon {
  id        String  @id @default(cuid())

  // Relations
  periodeId String
  periode   Periode @relation(fields: [periodeId], references: [id])

  layananId String
  layanan   Layanan @relation(fields: [layananId], references: [id])

  pegawaiId String
  pegawai   Pegawai @relation(fields: [pegawaiId], references: [id])

  // Demographics
  nama             String
  usia             Int
  jenisKelamin     String
  pendidikan       String
  pekerjaan        String
  isDifabel        String
  jenisDisabilitas String?
  tglLayanan       DateTime

  // SKM Scores (1-4 scale, 9 elements per Permenpan RB 14/2017)
  u1 Int
  u2 Int
  u3 Int
  u4 Int
  u5 Int
  u6 Int
  u7 Int
  u8 Int
  u9 Int

  // Employee star rating (1-5 scale)
  rating Int?

  saran     String?
  ipAddress String?
  createdAt DateTime @default(now())
}

// SYSTEM AUDIT LOG
model LogActivity {
  id        String   @id @default(cuid())
  action    String
  target    String
  details   String?
  timestamp DateTime @default(now())
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

// IP BLOCK — persisted in DB so blocks survive server restarts
model BlockedIp {
  id           String   @id @default(cuid())
  ip           String   @unique
  reason       String?  // "manual" | "auto" | custom reason
  blockedAt    DateTime @default(now())
  // Unblock request from the blocked user
  message      String?  // user's unblock request message
  messageAt    DateTime?
  messageEmail String?  // optional email for reply
}

// PUBLIC COMPLAINTS (Pengaduan Masyarakat)
model Pengaduan {
  id        String              @id @default(cuid())
  nama      String
  email     String
  telepon   String?
  judul     String
  isi       String
  status    String              @default("BARU") // BARU | DIPROSES | SELESAI
  createdAt DateTime            @default(now())
  lampiran  PengaduanLampiran[]
}

// COMPLAINT ATTACHMENTS (up to 5 per complaint)
model PengaduanLampiran {
  id          String    @id @default(cuid())
  pengaduanId String
  data        Bytes
  mimeType    String
  nama        String
  urutan      Int       @default(0)
  pengaduan   Pengaduan @relation(fields: [pengaduanId], references: [id], onDelete: Cascade)
}